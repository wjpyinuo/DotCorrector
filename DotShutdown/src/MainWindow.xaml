<Window
    x:Class="DotShutdown.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:DotShutdown.Converters"
    xmlns:hi="using:H.NotifyIcon"
    mc:Ignorable="d"
    Title="DotShutdown"
    Width="520" Height="680"
    MinWidth="480" MinHeight="640"
    ExtendsContentIntoTitleBar="True"
    SystemBackdrop="Mica">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <!-- Card Style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <!-- Section Label Style -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!-- Action Chip Button Style -->
        <Style x:Key="ChipButton" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,12,8,10" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Preset Chip Style -->
        <Style x:Key="PresetChip" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="48" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Cancel Button Style -->
        <Style x:Key="CancelButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{ThemeResource SystemFillColorCriticalBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource SystemFillColorCriticalBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Height" Value="40" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Time Input Style -->
        <Style x:Key="TimeInput" TargetType="NumberBox">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="44" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="SpinButtonPlacementMode" Value="Compact" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </Window.Resources>

    <!-- Tray Icon -->
    <hi:TaskbarIcon
        x:Name="TrayIcon"
        ToolTipText="DotShutdown - 就绪">

        <hi:TaskbarIcon.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem Text="显示主窗口" Click="OnTrayShowWindow" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="取消计划" Click="OnTrayCancel" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="退出" Click="OnTrayQuit" />
            </MenuFlyout>
        </hi:TaskbarIcon.ContextFlyout>
    </hi:TaskbarIcon>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="24" Spacing="0">

                <!-- Header -->
                <StackPanel Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="DotShutdown"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Text="v1.0"
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   VerticalAlignment="Bottom" Margin="0,0,0,4" />
                    </StackPanel>
                    <TextBlock Text="Windows 定时关机工具"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>

                <!-- Timer Card -->
                <Border Style="{StaticResource CardBorder}"
                        Margin="0,0,0,16" Padding="24,28,24,22">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="TimerDisplayText"
                                   Text="{x:Bind Vm.TimerDisplay, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="64" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center" Spacing="6"
                                    Margin="0,8,0,0">
                            <Ellipse x:Name="StatusDot"
                                     Width="6" Height="6"
                                     Fill="{ThemeResource SystemFillColorSuccessBrush}" />
                            <TextBlock Text="{x:Bind Vm.StatusText, Mode=OneWay}"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Action Selection -->
                <TextBlock Text="操作类型" Style="{StaticResource SectionLabel}" />
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource ChipButton}"
                            Click="OnActionClick" Tag="Shutdown">
                        <StackPanel Spacing="4">
                            <TextBlock Text="⏻" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock Text="关机" FontSize="11" FontWeight="Medium"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="1" Style="{StaticResource ChipButton}"
                            Click="OnActionClick" Tag="Restart" Margin="6,0,0,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="🔄" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock Text="重启" FontSize="11" FontWeight="Medium"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Style="{StaticResource ChipButton}"
                            Click="OnActionClick" Tag="Sleep" Margin="6,0,0,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="🌙" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock Text="睡眠" FontSize="11" FontWeight="Medium"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3" Style="{StaticResource ChipButton}"
                            Click="OnActionClick" Tag="Hibernate" Margin="6,0,0,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="💤" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock Text="休眠" FontSize="11" FontWeight="Medium"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4" Style="{StaticResource ChipButton}"
                            Click="OnActionClick" Tag="LogOff" Margin="6,0,0,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="🚪" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock Text="注销" FontSize="11" FontWeight="Medium"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Presets -->
                <TextBlock Text="快捷预设" Style="{StaticResource SectionLabel}" />
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource PresetChip}"
                            Content="15 分钟" Click="OnPresetClick" Tag="15" />
                    <Button Grid.Column="1" Style="{StaticResource PresetChip}"
                            Content="30 分钟" Click="OnPresetClick" Tag="30" Margin="6,0,0,0" />
                    <Button Grid.Column="2" Style="{StaticResource PresetChip}"
                            Content="1 小时" Click="OnPresetClick" Tag="60" Margin="6,0,0,0" />
                    <Button Grid.Column="3" Style="{StaticResource PresetChip}"
                            Content="2 小时" Click="OnPresetClick" Tag="120" Margin="6,0,0,0" />
                    <Button Grid.Column="4" Style="{StaticResource PresetChip}"
                            Content="4 小时" Click="OnPresetClick" Tag="240" Margin="6,0,0,0" />
                    <Button Grid.Column="5" Style="{StaticResource PresetChip}"
                            Content="8 小时" Click="OnPresetClick" Tag="480" Margin="6,0,0,0" />
                </Grid>

                <!-- Custom Time Input -->
                <TextBlock Text="自定义时间" Style="{StaticResource SectionLabel}" />
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="时" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4" />
                        <NumberBox x:Name="InputHourBox" Style="{StaticResource TimeInput}"
                                   Value="0" Minimum="0" Maximum="99"
                                   ValueChanged="OnTimeInputChanged" />
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text=":" FontSize="24" FontWeight="Light"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               VerticalAlignment="Bottom" Margin="8,0,8,8" />

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="分" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4" />
                        <NumberBox x:Name="InputMinBox" Style="{StaticResource TimeInput}"
                                   Value="30" Minimum="0" Maximum="59"
                                   ValueChanged="OnTimeInputChanged" />
                    </StackPanel>

                    <TextBlock Grid.Column="3" Text=":" FontSize="24" FontWeight="Light"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               VerticalAlignment="Bottom" Margin="8,0,8,8" />

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="秒" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4" />
                        <NumberBox x:Name="InputSecBox" Style="{StaticResource TimeInput}"
                                   Value="0" Minimum="0" Maximum="59"
                                   ValueChanged="OnTimeInputChanged" />
                    </StackPanel>
                </Grid>

                <!-- Primary Action Button -->
                <Button x:Name="StartButton"
                        Style="{StaticResource PrimaryButton}"
                        Content="{x:Bind Vm.ButtonLabel, Mode=OneWay}"
                        Click="OnStartClick"
                        Margin="0,0,0,12" />

                <!-- Cancel Button -->
                <Button x:Name="CancelButton"
                        Style="{StaticResource CancelButton}"
                        Content="✖  取消计划"
                        Click="OnCancelClick"
                        Visibility="{x:Bind Vm.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,12" />

                <!-- Options Card -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel Spacing="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ToggleSwitch Grid.Column="0" IsOn="{x:Bind Vm.ForceClose, Mode=TwoWay}"
                                          OffContent="" OnContent="" />
                            <TextBlock Grid.Column="1" Text="强制关闭应用程序"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       FontSize="13" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ToggleSwitch Grid.Column="0" IsOn="{x:Bind Vm.SoundAlert, Mode=TwoWay}"
                                          OffContent="" OnContent="" />
                            <TextBlock Grid.Column="1" Text="关机前声音提醒"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       FontSize="13" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ToggleSwitch Grid.Column="0" IsOn="{x:Bind Vm.ConfirmBeforeAction, Mode=TwoWay}"
                                          OffContent="" OnContent="" />
                            <TextBlock Grid.Column="1" Text="执行前二次确认"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       FontSize="13" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ToggleSwitch Grid.Column="0" IsOn="{x:Bind Vm.MinimizeToTray, Mode=TwoWay}"
                                          OffContent="" OnContent="" />
                            <TextBlock Grid.Column="1" Text="最小化到系统托盘"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       FontSize="13" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Status Bar -->
                <Grid Padding="10,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="⚡" FontSize="12" />
                        <TextBlock Text="{x:Bind Vm.FooterStatus, Mode=OneWay}"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                        <HyperlinkButton Content="设置" FontSize="12" Padding="0"
                                         Click="OnSettingsClick" />
                        <HyperlinkButton Content="关于" FontSize="12" Padding="0"
                                         Click="OnAboutClick" />
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
