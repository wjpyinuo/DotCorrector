<Window
    x:Class="DotShutdown.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:DotShutdown.Converters"
    Title="DotShutdown"
    Width="520" Height="680"
    MinWidth="480" MinHeight="640"
    ExtendsContentIntoTitleBar="True">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="24">

                <!-- Header -->
                <TextBlock Text="DotShutdown"
                           FontSize="28" FontWeight="Bold"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           Margin="0,0,0,20"/>

                <!-- Timer Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="24,28,24,22" Margin="0,0,0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="TimerDisplayText"
                                   Text="{x:Bind Vm.TimerDisplay, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="64" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="{x:Bind Vm.StatusText, Mode=OneWay}"
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Action Selection -->
                <TextBlock Text="操作类型" FontSize="13" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="⏻ 关机" Click="OnActionClick" Tag="Shutdown"
                            HorizontalAlignment="Stretch" Margin="0,0,3,0"/>
                    <Button Grid.Column="1" Content="🔄 重启" Click="OnActionClick" Tag="Restart"
                            HorizontalAlignment="Stretch" Margin="3,0,3,0"/>
                    <Button Grid.Column="2" Content="🌙 睡眠" Click="OnActionClick" Tag="Sleep"
                            HorizontalAlignment="Stretch" Margin="3,0,3,0"/>
                    <Button Grid.Column="3" Content="💤 休眠" Click="OnActionClick" Tag="Hibernate"
                            HorizontalAlignment="Stretch" Margin="3,0,3,0"/>
                    <Button Grid.Column="4" Content="🚪 注销" Click="OnActionClick" Tag="LogOff"
                            HorizontalAlignment="Stretch" Margin="3,0,0,0"/>
                </Grid>

                <!-- Presets -->
                <TextBlock Text="快捷预设" FontSize="13" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="15分" Click="OnPresetClick" Tag="15"
                            HorizontalAlignment="Stretch" Margin="0,0,3,0"/>
                    <Button Grid.Column="1" Content="30分" Click="OnPresetClick" Tag="30"
                            HorizontalAlignment="Stretch" Margin="3,0,3,0"/>
                    <Button Grid.Column="2" Content="1时" Click="OnPresetClick" Tag="60"
                            HorizontalAlignment="Stretch" Margin="3,0,3,0"/>
                    <Button Grid.Column="3" Content="2时" Click="OnPresetClick" Tag="120"
                            HorizontalAlignment="Stretch" Margin="3,0,3,0"/>
                    <Button Grid.Column="4" Content="4时" Click="OnPresetClick" Tag="240"
                            HorizontalAlignment="Stretch" Margin="3,0,3,0"/>
                    <Button Grid.Column="5" Content="8时" Click="OnPresetClick" Tag="480"
                            HorizontalAlignment="Stretch" Margin="3,0,0,0"/>
                </Grid>

                <!-- Custom Time Input -->
                <TextBlock Text="自定义时间" FontSize="13" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="InputHourBox" Text="0"
                             FontFamily="Consolas" FontSize="20"
                             HorizontalAlignment="Stretch"
                             HorizontalContentAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text=" : " FontSize="24"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="2" x:Name="InputMinBox" Text="30"
                             FontFamily="Consolas" FontSize="20"
                             HorizontalAlignment="Stretch"
                             HorizontalContentAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text=" : " FontSize="24"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="4" x:Name="InputSecBox" Text="0"
                             FontFamily="Consolas" FontSize="20"
                             HorizontalAlignment="Stretch"
                             HorizontalContentAlignment="Center"/>
                </Grid>

                <!-- Start Button -->
                <Button x:Name="StartButton"
                        Content="{x:Bind Vm.ButtonLabel, Mode=OneWay}"
                        Click="OnStartClick"
                        HorizontalAlignment="Stretch" Height="48"
                        Margin="0,0,0,12"/>

                <!-- Cancel Button -->
                <Button x:Name="CancelButton"
                        Content="✖ 取消计划"
                        Click="OnCancelClick"
                        HorizontalAlignment="Stretch" Height="40"
                        Visibility="{x:Bind Vm.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,12"/>

                <!-- Options -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <ToggleSwitch Header="强制关闭应用程序"
                                      IsOn="{x:Bind Vm.ForceClose, Mode=TwoWay}"/>
                        <ToggleSwitch Header="关机前声音提醒"
                                      IsOn="{x:Bind Vm.SoundAlert, Mode=TwoWay}"/>
                        <ToggleSwitch Header="执行前二次确认"
                                      IsOn="{x:Bind Vm.ConfirmBeforeAction, Mode=TwoWay}"/>
                        <ToggleSwitch Header="最小化到系统托盘"
                                      IsOn="{x:Bind Vm.MinimizeToTray, Mode=TwoWay}"/>
                    </StackPanel>
                </Border>

                <!-- Status Bar -->
                <TextBlock Text="{x:Bind Vm.FooterStatus, Mode=OneWay}"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
